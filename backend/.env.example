# Copiar a backend/.env y ajustar.
# El backend lee este archivo al arrancar (via python-dotenv).
# Las variables ya seteadas en el entorno tienen prioridad sobre este archivo.

# Puerto serial del Arduino
#   Windows:  COM3, COM4, ...
#   Linux:    /dev/ttyACM0, /dev/ttyUSB0, ...
#   macOS:    /dev/tty.usbmodem14101, ...
# Si se deja vacío, el backend intenta autodetectar.
ARDUINO_PORT=COM3
ARDUINO_BAUDRATE=115200

# Modelos
MODEL_CNN_PATH=models/cnn_base/model.pt
CONFIDENCE_THRESHOLD=0.85

# Logging
LOG_LEVEL=INFO

# Dashboard
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
